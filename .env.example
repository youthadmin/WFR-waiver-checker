# Copy to .env and fill in real values. Never commit .env.

# ── PCO API (reads only) ────────────────────────────────────────────
# Personal Access Token from https://api.planningcenteronline.com/oauth/applications
# Reuse the same pair used by ~/Documents/Agents/pco-automation/.env
PCO_CLIENT_ID=
PCO_SECRET=

# ── Signups in scope ────────────────────────────────────────────────
SIGNUP_YOUTH_CAMP=3526683
SIGNUP_DREAM_TEAM=3527418

# ── Waiver email source ─────────────────────────────────────────────
WAIVER_SENDER=nharrison@younglife.org
WAIVER_SUBJECT=WFR waiver form

# ── Notification destination ────────────────────────────────────────
NOTIFY_EMAIL=youthadmin@mannahouse.church

# ── Run mode ────────────────────────────────────────────────────────
# DRY_RUN=true → Playwright reads each attendee page but never clicks.
# First two production runs MUST be true; flip to false after manual review.
DRY_RUN=true

# Playwright browser config
HEADLESS=true              # false = headed (local debugging only)
RECORD_VIDEO=true          # true for first 5 runs, then set false

# ── Matching ────────────────────────────────────────────────────────
# rapidfuzz threshold; below this → manual review queue, never auto-click.
MATCH_THRESHOLD=90

# ── Guardrails (do not change without thought) ──────────────────────
MAX_ATTENDEES_PER_RUN=50
RUN_TIMEOUT_MINUTES=20
